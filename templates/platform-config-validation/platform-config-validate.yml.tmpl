# Optional platform/deploy config schema validation.
#
# Enable by copying this file to:
#   .github/workflows/platform-config-validate.yml
#
# The reusable workflow validates matching YAML files against
# @extratoast/deploy-config-schema. Keep this workflow opt-in for repos that
# actually carry platform/deploy config, and pin the reusable workflow to a
# release tag instead of @main once a stable tag is available.
name: Platform Config Validate

on:
  pull_request:
    paths:
      - "platform/**/*.yml"
      - "platform/**/*.yaml"
      - "deploy/**/*.yml"
      - "deploy/**/*.yaml"
      - ".github/workflows/platform-config-validate.yml"
  push:
    branches: [main]
    paths:
      - "platform/**/*.yml"
      - "platform/**/*.yaml"
      - "deploy/**/*.yml"
      - "deploy/**/*.yaml"
      - ".github/workflows/platform-config-validate.yml"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  platform-config-validate:
    name: Platform Config Validate
    uses: ExtraToast/github-workflows/.github/workflows/platform-config-validate.yml@main
    with:
      config-paths: |
        platform/**/*.yml
        platform/**/*.yaml
        deploy/**/*.yml
        deploy/**/*.yaml
      schema-kind: auto
