# Dependabot dependency policy template.
#
# Replace placeholders before use:
# - Add more entries to each `directories` list when a repo has multiple roots.
# - {{default_branch}}: default branch for pull-request-triggered workflows
#
# Policy:
# - 7-day cooldown for newly published versions.
# - Minor/patch version updates are grouped.
# - Security updates are grouped separately.
# - Major updates are outside version-update groups and open as isolated PRs.
version: 2

updates:
  - package-ecosystem: npm
    directories:
      - "{{npm_directory}}"
    schedule:
      interval: weekly
    cooldown:
      default-days: 7
    open-pull-requests-limit: 5
    groups:
      npm:
        applies-to: version-updates
        update-types: [minor, patch]
        patterns: ["*"]
      npm-security:
        applies-to: security-updates
        patterns: ["*"]

  - package-ecosystem: gradle
    directories:
      - "{{gradle_directory}}"
    schedule:
      interval: weekly
    cooldown:
      default-days: 7
    open-pull-requests-limit: 5
    groups:
      gradle:
        applies-to: version-updates
        update-types: [minor, patch]
        patterns: ["*"]
      gradle-security:
        applies-to: security-updates
        patterns: ["*"]

  - package-ecosystem: docker
    directories:
      - "{{docker_directory}}"
    schedule:
      interval: weekly
    cooldown:
      default-days: 7
    open-pull-requests-limit: 5
    groups:
      docker:
        applies-to: version-updates
        update-types: [minor, patch]
        patterns: ["*"]
      docker-security:
        applies-to: security-updates
        patterns: ["*"]

  - package-ecosystem: github-actions
    directory: /
    schedule:
      interval: weekly
    cooldown:
      default-days: 7
    open-pull-requests-limit: 5
    groups:
      actions:
        applies-to: version-updates
        update-types: [minor, patch]
        patterns: ["*"]
      actions-security:
        applies-to: security-updates
        patterns: ["*"]
