root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,json5}]
indent_style = space
indent_size = 2

[*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,vue,css,scss,html}]
indent_style = space
indent_size = 2

[*.{kt,kts}]
indent_style = space
indent_size = 4

[*.{sh,tf,nix}]
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf
