#!/usr/bin/env sh
# DESIGN-ONLY SKELETON: OpenTelemetry entrypoint wrapper.
# Intended to be composed with a concrete service Dockerfile, not used as a
# global shared entrypoint without review.
set -eu

: "${OTEL_SERVICE_NAME:={{otel_service_name}}}"
: "${OTEL_EXPORTER_OTLP_ENDPOINT:={{otel_exporter_otlp_endpoint}}}"
: "${OTEL_RESOURCE_ATTRIBUTES:={{otel_resource_attributes}}}"
: "${JAVA_OPTS:={{java_opts}}}"

if [ "{{otel_java_agent_enabled}}" = "true" ]; then
  JAVA_OPTS="${JAVA_OPTS} -javaagent:{{otel_java_agent_path}}"
fi

export OTEL_SERVICE_NAME
export OTEL_EXPORTER_OTLP_ENDPOINT
export OTEL_RESOURCE_ATTRIBUTES
export JAVA_OPTS

exec "$@"
